APP_NAME=karaoke-ai-api
APP_ENV=development
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg://karaoke:karaoke@localhost:5432/karaoke_ai
REDIS_URL=redis://localhost:6379/0
STORAGE_MODE=local
LOCAL_STORAGE_ROOT=storage
MODEL_ROOT=models
FASTER_WHISPER_MODEL_DIR=models/faster-whisper
FASTER_WHISPER_MODEL_NAME=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5
WHISPERX_MODEL_DIR=models/whisperx
WHISPERX_DEVICE=cpu
WHISPERX_DEFAULT_ALIGN_LANGUAGE=es
SEPARATION_MODEL_DIR=models/audio-separator
SEPARATION_MODEL_FILENAME=UVR_MDXNET_KARA_2.onnx
SEPARATION_OUTPUT_FORMAT=wav
ALLOW_MODEL_DOWNLOADS=false
EXTERNAL_LYRICS_PROVIDER=none
LRCLIB_BASE_URL=https://lrclib.net/api
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=100
CELERY_WORKER_POOL=threads
CELERY_WORKER_CONCURRENCY=3
CELERY_WORKER_PREFETCH_MULTIPLIER=1
